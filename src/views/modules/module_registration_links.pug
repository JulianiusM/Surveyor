//- views/mixins/module_registration_links.pug
//- Collapsible admin section for single-use registration links (deadline bypass)
//- Params:
//-   opts: {
//-     eventId: string,
//-     apiList: string,    // GET   /api/event/:id/links
//-     apiCreate: string,  // POST  /api/event/:id/links
//-     apiRevoke: string   // DELETE /api/event/:id/links/:linkId
//-     title?: string
//-     help?: string
//-   }

mixin eventRegLinks(opts)
    - const title = opts?.title ?? 'Registration links'
    - const help = opts?.help ?? 'Create single-use links that allow participants to register even after the binding deadline. You can set an optional expiry.'
    - const accId = 'ev-links-' + Math.random().toString(36).slice(2)

    .reg-links.text-bg-dark.border.border-secondary.rounded-2.py-1.my-2(
        data-api-list=opts.apiList
        data-api-create=opts.apiCreate
        data-api-revoke=opts.apiRevoke
        data-event-id=opts.eventId
    )
        .accordion.accordion-flush(id=accId)
            .accordion-item.bg-dark.border-secondary
                h2.accordion-header
                    button.accordion-button.text-light.bg-dark.collapsed(
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=`#${accId}-col`
                        aria-expanded="false"
                        aria-controls=`${accId}-col`
                    )
                        i.bi.bi-link-45deg.me-2
                        | #{title}
                        span.badge.bg-secondary.ms-2.js-count 0
                .accordion-collapse.collapse(id=`${accId}-col` data-bs-parent=`#${accId}`)
                    .accordion-body.bg-dark
                        .d-flex.flex-wrap.gap-2.justify-content-between.align-items-center.mb-3
                            small.text-secondary= help
                            .btn-toolbar.gap-2
                                button.btn.btn-sm.btn-outline-light(type="button" data-bs-toggle="modal" data-bs-target=`#${accId}-new`)
                                    i.bi.bi-plus-circle.me-1
                                    | Create link

                        //- List
                        .table-responsive
                            table.table.table-dark.table-striped.table-bordered.align-middle.mb-0
                                thead
                                    tr
                                        th Token
                                        th Created
                                        th Expires
                                        th Status
                                        th.text-end Actions
                                tbody.js-rows
                                    tr.js-empty
                                        td(colspan="5")
                                            .text-secondary.small No links yet.

        //- Create Link Modal
        .modal.fade(id=`${accId}-new`, tabindex="-1", aria-labelledby=`${accId}-new-title`, aria-hidden="true")
            .modal-dialog.modal-dialog-centered
                .modal-content.bg-dark.text-light.border.border-secondary
                    .modal-header
                        h5.modal-title(id=`${accId}-new-title`) Create registration link
                        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal" aria-label="Close")
                    .modal-body
                        form
                            .row.g-3
                                .col-md-6
                                    label.form-label(for=`${accId}-uses`)
                                        i.bi.bi-hash.me-1
                                        | Uses
                                    input.form-control.text-bg-dark(id=`${accId}-uses` type="number" min="1" step="1" value="1" placeholder="1")
                                    small.text-secondary.d-block Single-use by default (1).
                                .col-md-6
                                    label.form-label(for=`${accId}-exp`)
                                        i.bi.bi-calendar2-event.me-1
                                        | Expires (optional, local time)
                                    input.form-control.text-bg-dark(id=`${accId}-exp` type="datetime-local")
                                    small.text-secondary.d-block Leave empty to never expire.
                    .modal-footer
                        button.btn.btn-outline-secondary(type="button" data-bs-dismiss="modal") Cancel
                        button.btn.btn-primary.btn-create-submit(type="button" data-modal=`#${accId}-new`)
                            span.label Create
                            span.spinner-border.spinner-border-sm.ms-2.d-none(role="status" aria-hidden="true")

    script(type="module").
        import { initRegLinks } from "/js/modules/reg-links.gen.js";
        initRegLinks();