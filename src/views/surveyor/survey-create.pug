//- views/survey/survey-create.pug  – Facelifted Create Survey Page
extends ../layout

block meta
    title Create Survey | Surveyor

block title
    h1.card-header.text-center
        i.bi.bi-clipboard-plus-fill.me-2
        | Create Survey

block content
    -
        let parsed, parsedData;
        if (data) {
            if (data.entity) {
                parsed = data.entity;
            } else {
                parsed = {
                    description: data.description,
                }
            }
            if (data.data) {
                parsedData = data.data;
            } else {
                parsedData = data.combinations;
            }
        } else {
            parsed = {};
            parsedData = [];
        }

    form#surveyForm.row.gy-4.justify-content-center(action="/survey/create" method="POST")
        //── Survey Title ─────────────────────────────────────
        .col-md-12
            label.form-label.mb-1(for="title")
                i.bi.bi-tag.me-1
                | Survey Title *
            input#title.form-control.text-bg-dark(
                type="text"
                name="title"
                required
                value= data && data.title ? data.title : '')

        .col-md-12
            label.form-label(for="desc")
                i.bi.bi-pencil-square.me-1
                | Description
            textarea#description.form-control.text-bg-dark(name="description"
                value=(parsed.description ? parsed.description : ''))

        //── Combinations Table ────────────────────────────────
        .col-12
            label.form-label.mb-2
                i.bi.bi-calendar4-week.me-1
                | Select date combinations
            .table-responsive
                table.table.table-dark.table-hover.table-bordered.align-middle
                    thead
                        tr
                            th.text-center.w-50 Weekday
                            th.text-center.w-40 Week of month
                            th.text-center.w-10 Action
                    tbody#combinationTable

        // Buttons
        .d-flex.justify-content-between.align-items-center
            button#addCombinationBtn.btn.btn-outline-info(type="button")
                i.bi.bi-plus-circle.me-1
                | Add combination
            button.btn.btn-success(type="submit")
                i.bi.bi-check-lg.me-1
                | Create Survey

block scripts
    script(type="module" src="/js/survey-create.gen.js")
    if data && data.isDuplicate
        script.
            window.PREFILLED_COMBINATIONS = !{JSON.stringify(parsedData)};
            window.IS_MANAGE = true;