extends ../layout

block meta
    title Create Activity Plan | Surveyor

block title
    .card-header.d-flex.justify-content-between.align-items-center
        h1.card-title.mb-0
            i.bi.bi-calendar-plus.me-2
            | Create activity plan
        a.btn.btn-sm.btn-outline-light(href="/help/activity_plans" title="Help with activity plans")
            i.bi.bi-question-circle

block content
    -
        let parsed = {}, parsedData = [], parsedEventData = {};
        if (data) {
            if (data.entity) {
                parsed = data.entity;
            } else {
                parsed = data;
            }
            if (data.data) {
                parsedData = data.data;
            } else {
                parsedData = data.slots;
            }
            if (data.eventId) {
                parsedEventData.id = data.eventId;
            }
            if (data.events) {
                parsedEventData.events = data.events;
            }
        }
        let eventIdQuery = '';
        if (parsed.eventId) {
            eventIdQuery = `?eventId=${parsed.eventId}`
        }

    form#planForm(action=`/activity/create${eventIdQuery}` method="post")
        .row.g-3.mb-3
            .col-md-6
                label.form-label(for="title")
                    i.bi.bi-tag.me-1
                    | Title *
                input#title.form-control.text-bg-dark(
                    type="text" name="title" required
                value=(parsed.title || ''))
            .col-md-3
                label.form-label(for="start")
                    i.bi.bi-calendar-event.me-1
                    | Start date *
                input#startDate.form-control.text-bg-dark(
                    type="date" name="startDate" required
                value=(parsed.startDate || ''))
            .col-md-3
                label.form-label(for="end")
                    i.bi.bi-calendar-range.me-1
                    | End date *
                input#endDate.form-control.text-bg-dark(
                    type="date" name="endDate" required
                value=(parsed.endDate || ''))

        .row.g-3.mb-3
            .col-md-12
                label.form-label(for="desc")
                    i.bi.bi-pencil-square.me-1
                    | Description
                textarea#desc.form-control.text-bg-dark(name="description")
                    | #{parsed.description || ''}

        .row.g-3.mb-3
            .col-md-12
                +entityPicker('event_id', parsedEventData.events, {label: 'Assign to event', value: parsedEventData.id})

        .row.g-3.mb-3
            .col-md-12
                +permMatrix(['participant', 'guest', 'authenticated', 'public'], perms.permMeta, perms.defaultPerms, perms.presets, 'defaultPerms')

        hr

        // dynamic slot area
        #slotArea

        // hidden json payload
        input(type="hidden" id="slotsJson" name="slots")

        .d-grid.mt-4
            button.btn.btn-success(type="submit")
                i.bi.bi-check-lg.me-1
                | Create plan

block scripts
    script(type="module" src="/js/activity-create.gen.js")
    if data && data.isDuplicate
        script.
            window.Surveyor.prefilledSlots = !{JSON.stringify(parsedData)};
