extends ../layout

block meta
    title Create Activity Plan | Surveyor

block title
    h1.card-header.text-center
        i.bi.bi-calendar-plus.me-2
        | Create activity plan

block content
    -
        let parsed = {}, parsedData = [];
        if (data) {
            if (data.entity) {
                parsed = data.entity;
            } else {
                parsed = data;
            }
            if (data.data) {
                parsedData = data.data;
            } else {
                parsedData = data.slots;
            }
        }
        let eventIdQuery = '';
        if (parsed.eventId) {
            eventIdQuery = `?eventId=${parsed.eventId}`
        }

    form#planForm(action=`/activity/create${eventIdQuery}` method="post")
        .row.g-3.mb-3
            .col-md-6
                label.form-label(for="title")
                    i.bi.bi-tag.me-1
                    | Title *
                input#title.form-control.text-bg-dark(
                    type="text" name="title" required
                value=(parsed.title || ''))
            .col-md-3
                label.form-label(for="start")
                    i.bi.bi-calendar-event.me-1
                    | Start date *
                input#startDate.form-control.text-bg-dark(
                    type="date" name="startDate" required
                value=(parsed.startDate || ''))
            .col-md-3
                label.form-label(for="end")
                    i.bi.bi-calendar-range.me-1
                    | End date *
                input#endDate.form-control.text-bg-dark(
                    type="date" name="endDate" required
                value=(parsed.endDate || ''))

        // Options (like packing list)
        .row.g-3.mb-3
            .col-md-6.d-flex.align-items-end
                .form-check
                    input#allowAdd.form-check-input(
                        type="checkbox" name="allowGuestAdd"
                        checked=!!parsed.allowGuestAdd)
                    label.form-check-label(for="allowAdd")
                        i.bi.bi-plus-circle.me-1
                        | Guests can add slots
            .col-md-6.d-flex.align-items-end
                .form-check
                    input#guestManage.form-check-input(
                        type="checkbox" name="guestManage"
                        checked=!!parsed.guestManage)
                    label.form-check-label(for="guestManage")
                        i.bi.bi-tools.me-1
                        | Guests may manage
                        span.badge.bg-danger.ms-1 DANGER

        .row.g-3.mb-3
            .col-md-12
                label.form-label(for="desc")
                    i.bi.bi-pencil-square.me-1
                    | Description
                textarea#desc.form-control.text-bg-dark(name="description")
                    | #{parsed.description || ''}

        hr

        // dynamic slot area
        #slotArea

        // hidden json payload
        input(type="hidden" id="slotsJson" name="slots")

        .d-grid.mt-4
            button.btn.btn-success(type="submit")
                i.bi.bi-check-lg.me-1
                | Create plan

block scripts
    script(type="module" src="/js/activity-create.gen.js")
    if data && data.isDuplicate
        script.
            window.PREFILLED_SLOTS = !{JSON.stringify(parsedData)};
            window.IS_MANAGE = true;
