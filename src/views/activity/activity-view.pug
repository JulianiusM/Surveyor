extends ../layout

block meta
    title #{data.plan.title} | Activity planner

block title
    h1.card-header.text-center
        i.bi.bi-calendar-check.me-2
        | #{data.plan.title}

block content
    //- helper in pug (this won’t be sent to the client)
    -
        function fmtISO(date) {
            const y = date.getUTCFullYear();
            const m = String(date.getUTCMonth() + 1).padStart(2, '0');
            const d = String(date.getUTCDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function toDate(val) {
            const [y, m, d] = val.split('-').map(Number);
            return new Date(Date.UTC(y, m - 1, d));
        }
        const dayNames = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
        const start = toDate(data.plan.startDate);
        const end = toDate(data.plan.endDate);

        const weeks = [];
        const monday = new Date(start);
        monday.setDate(monday.getDate() - ((monday.getDay() + 6) % 7));
        while (monday <= end) {
            weeks.push(new Date(monday));
            monday.setDate(monday.getDate() + 7);
        }

    // ─── Description (editable) ──────────────────────────────
    if permData.entity.has('EDIT_DESC')
        // manager sees pointer
        small.text-info.fst-italic.fw-light Double click to edit
        p#planDesc.border.border-secondary.rounded.p-1(
            style="cursor:pointer"
            data-edit="planDescription"
        )
            if data.plan.description
                - const lines = data.plan.description.split('\n')
                each line, i in lines
                    | #{line}
                    if i < lines.length - 1
                        br
            else
                em.text-secondary double-click to add description
        hr.mb-1.mt-0
    else if data.plan.description
        p#planDesc.mb-0.mt-2
            - const lines = data.plan.description.split('\n')
            each line, i in lines
                | #{line}
                if i < lines.length - 1
                    br
        hr.mb-1.mt-0

    // Owner settings toggles
    if permData.entity.has('MANAGE_PERMISSIONS')
        +permissionManagement(admins, perms.permMeta, perms.defaultPerms, perms.presets, {
            entityType: 'activity',
            entityId: data.plan.id
        })

    //Erste Zeile: Metainfos / Badge
    .d-flex.justify-content-between.align-items-center.mb-3
        //- Titel / Hauptlabel links
        span.fs-6.fw-semibold
            i.bi.bi-people-fill.me-1
            | Participants:
            span.badge.bg-light.text-dark.ms-1 #{data.counters.participants}

        //── Items + Offene / Leere
        span.fs-6.fw-semibold
            i.bi.bi-card-checklist.me-1
            | Slots:
            span.badge.bg-light.text-dark.ms-1 #{data.slots.length}
            span.badge.bg-secondary-subtle.text-secondary-emphasis.ms-1
                i.bi.bi-box-arrow-up-right.me-1
                | #{data.counters.open} open
            span.badge.bg-danger-subtle.text-danger-emphasis.ms-1
                i.bi.bi-slash-circle.me-1
                | #{data.counters.empty} unassigned

    if permData.entity.has('MANAGE_REQUIREMENTS')
        .card.text-bg-dark.border.border-secondary-subtle.mb-3#requirementPanel
            .card-header.d-flex.justify-content-between.align-items-center
                span.d-flex.align-items-center.gap-2
                    i.bi.bi-gear-wide-connected
                    span Requirement settings
                .d-flex.gap-2
                    button.btn.btn-sm.btn-outline-secondary(type="button" data-requirements-refresh)
                        i.bi.bi-arrow-clockwise.me-1
                        | Reload
                    button.btn.btn-sm.btn-success(type="button" data-requirements-save)
                        i.bi.bi-save.me-1
                        | Save settings
            .card-body
                p.text-secondary.small.mb-3 Define required shifts, rounding, and optional overrides for participants. Leave counts empty to skip enforcement.
                form#requirementForm
                    .row.g-3
                        .col-md-3
                            label.form-label(for="assignmentMode") Assignment mode
                            select#assignmentMode.form-select.form-select-sm.text-bg-dark
                                option(value="FREE") Free
                                option(value="REQUIRED") Required
                        .col-md-3
                            label.form-label(for="requiredShifts") General required shifts
                            input#requiredShifts.form-control.form-control-sm.text-bg-dark(type="number" min="0" placeholder="e.g. 2")
                        .col-md-3
                            label.form-label(for="roundingMode") Rounding mode
                            select#roundingMode.form-select.form-select-sm.text-bg-dark
                                option(value="") None
                                option(value="CEIL") Ceil
                                option(value="ROUND") Round
                                option(value="FLOOR") Floor
                        .col-md-3
                            label.form-label(for="bindingDeadline") Binding deadline
                            input#bindingDeadline.form-control.form-control-sm.text-bg-dark(type="datetime-local" placeholder="optional")
                    .form-check.form-switch.my-3
                        input#allowOverfill.form-check-input(type="checkbox" role="switch")
                        label.form-check-label(for="allowOverfill") Allow assignments beyond slot capacity
                    .row.g-3
                        .col-md-6
                            .form-check.form-switch
                                input#allowArrivalEvening.form-check-input(type="checkbox" role="switch")
                                label.form-check-label(for="allowArrivalEvening") Allow arrival-day evening assignments
                        .col-md-6
                            .form-check.form-switch
                                input#allowDepartureMorning.form-check-input(type="checkbox" role="switch")
                                label.form-check-label(for="allowDepartureMorning") Allow departure-day morning assignments

                    hr
                    h6.d-flex.justify-content-between.align-items-center
                        span Role requirements
                        small.text-secondary Set per-role required shift counts
                    .row.g-2#roleRequirementList
                    hr
                    h6.d-flex.justify-content-between.align-items-center
                        span Participant overrides
                        button.btn.btn-sm.btn-outline-info(type="button" data-add-override)
                            i.bi.bi-plus-lg.me-1
                            | Add override
                    p.text-secondary.small.mb-2 Specify user/guest IDs and optional roles to override shift counts for specific participants.
                    .d-grid.gap-2#overrideList
                    hr
                    h6.d-flex.justify-content-between.align-items-center
                        span Participant requirements
                        small.text-secondary Remaining vs assigned per attendee
                    .table-responsive
                        table.table.table-dark.table-bordered.mb-0
                            thead
                                tr
                                    th Participant
                                    th.text-center Required / Assigned
                                    th.text-center Remaining
                                    th.text-center Attendance
                                    th.text-center Source
                            tbody#requirementSummaryBody
                                tr(data-empty-state)
                                    td.colspan-5.text-center.text-secondary.pt-3 No participants yet.
                .alert.alert-info.py-2.px-3.mt-3.d-none(role="alert" data-requirements-alert)
                    i.bi.bi-exclamation-circle.me-2
                    span

    each week in weeks
        h4.mt-4.mb-2 Week of #{fmtISO(week)}
        .table-responsive
            if permData.entity.has('ITEM_EDIT')
                small.text-info.fst-italic.fw-light Double click to edit, drag to reorder
            table.table.table-dark.table-bordered.activity-table
                thead
                    tr
                        // @formatter:off
                        - for (let i = 0; i < 7; i++) {
                        -   const cur = new Date(week); cur.setDate(cur.getDate() + i);
                        -   if (cur < start || cur > end) continue;
                            th.text-center.small(data-date=fmtISO(cur))
                                span.day #{dayNames[i]}
                                br
                                span.date #{fmtISO(cur)}
                        - }
                        // @formatter:on
                tbody
                    //- figure out how many rows we need
                    // @formatter:off
                    // iterate 7 weekdays once
                    - for (let i = 0; i < 7; i++) {
                    - const cur = new Date(week); cur.setDate(cur.getDate() + i)
                    - if (cur < start || cur > end) continue;
                        td
                            // ▶ every slot now shares this parent
                            .slot-container(data-date=fmtISO(cur))
                                - const daySlots = (data.slots[fmtISO(cur)] || []);
                                if daySlots.length > 0
                                    each slot, idx in daySlots
                                        - const my = data.assignments.includes(slot.id)
                                        - const startTime = slot.startTime ? slot.startTime.slice(0, 5) : null
                                        - const endTime = slot.endTime ? slot.endTime.slice(0, 5) : null
                                        .slot.border.rounded.p-2.mb-2.d-grid.gap-1.draggable(
                                            data-slotid=slot.id
                                            data-day=slot.day
                                            data-start=slot.startTime
                                            data-end=slot.endTime
                                            draggable=permData.entity.has('ITEM_EDIT') ? 'true' : null)

                                            // editable title
                                            span.fw-bold.text-center(data-edit="title" data-id=slot.id)= slot.title
                                            if startTime || endTime
                                                small.text-info.text-center(data-time-range)
                                                    i.bi.bi-clock-history.me-1
                                                    | #{startTime || '??'}
                                                    |  – 
                                                    | #{endTime || '??'}
                                            hr.m-0

                                            // editable description
                                            if permData.itemAllow(slot.id, 'EDIT_DESC', 'ITEM_EDIT')
                                                span.border.border-secondary.rounded.p-1.fw-5(data-edit="description" data-id=slot.id)= slot.description || ''
                                            else
                                                span.fw-5(data-edit="description" data-id=slot.id)= slot.description || ''

                                            - const slotRoles = (data.roles.slotRoles ? data.roles.slotRoles[slot.id] || [] : []);
                                            if slotRoles.length > 0
                                                for slotRole in slotRoles
                                                    +roleAssignmentAddon(slot.id, slotRole.name, slotRole.description || slotRole.name, data.assigneeLists[slot.id], user, guest)

                                            // badge + editable max
                                            span.badge.bg-secondary.w-100.text-center
                                                span(data-count)= slot.assignedCount
                                                |  /&nbsp;
                                                span(data-edit="maxAssignees" data-id=slot.id data-max)= slot.maxAssignees

                                            // assignees
                                            ul.list-unstyled.mb-0
                                                each asg in data.assigneeLists[slot.id] || []
                                                    li.d-flex.align-items-center.gap-1
                                                        i.bi.bi-person-fill
                                                        span.flex-grow-1= asg.name
                                                        if manage
                                                            button.btn.btn-sm.btn-outline-danger.ms-1(
                                                                data-owner-remove
                                                                data-assignid=asg.id) ×

                                            // actions
                                            .d-flex.gap-2.mt-1
                                                if my
                                                    button.btn.btn-sm.btn-outline-danger.flex-grow-1(
                                                        data-action="unassign") Leave
                                                else if slot.assignedCount < slot.maxAssignees
                                                    button.btn.btn-sm.btn-outline-success.flex-grow-1(
                                                        data-action="assign") Join
                                                else
                                                    span.badge.bg-secondary.flex-grow-1.text-center Full
                                                if permData.itemAllow(slot.id, 'ITEM_DELETE', 'ITEM_DELETE')
                                                    button.btn.btn-sm.btn-outline-danger(
                                                        data-delete-slot data-slotid=slot.id
                                                        draggable="false")
                                                        i.bi.bi-trash
                                            if permData.itemAllow(slot.id, 'EDIT_META', 'ITEM_EDIT')
                                                +roleAssignmentSlotCreator(slot.id, data.roles.allRoles)
                                else
                                    span.badge.w-100.text-center
                                        i.bi.bi-info-circle.me-2
                                        | No slots for this day!
                    - }
                    // @formatter:on
                // ★ add-slot buttons row
                if permData.entity.has('ITEM_ADD')
                    tfoot
                        tr
                            // @formatter:off
                            - for(let i=0;i<7;i++){
                            - const cur=new Date(week);cur.setDate(cur.getDate() + i)
                            - if(cur<start||cur>end) continue;
                                td.text-center
                                    button.btn.btn-sm.btn-outline-info.w-100(data-add-slot data-date=fmtISO(cur)) + Slot
                            - }
                            // @formatter:on

    if permData.entity.has('MANAGE_ASSIGNMENTS')
        hr
        .card.text-bg-dark.border.border-secondary-subtle#recommendationPanel
            .card-header.d-flex.justify-content-between.align-items-center
                span.d-flex.align-items-center.gap-2
                    i.bi.bi-magic.me-1
                    span Assignment recommendations
                .d-flex.gap-2
                    button.btn.btn-sm.btn-outline-secondary(type="button" data-recommendations-refresh)
                        i.bi.bi-arrow-clockwise.me-1
                        | Reload
                    button.btn.btn-sm.btn-outline-primary(type="button" data-recommendations-auto)
                        i.bi.bi-stars.me-1
                        | Auto-generate
                    button.btn.btn-sm.btn-success(type="button" data-recommendations-save)
                        i.bi.bi-save.me-1
                        | Save edits
                    button.btn.btn-sm.btn-warning(type="button" data-recommendations-apply)
                        i.bi.bi-check2-circle.me-1
                        | Apply approved
            .card-body
                p.text-secondary.small.mb-3 Review automatically generated or manually edited assignments before applying them to slots.
                .alert.alert-info.py-2.px-3.d-none(role="alert" data-recommendations-alert)
                    i.bi.bi-info-circle.me-2
                    span
                .table-responsive
                    table.table.table-dark.table-bordered.mb-0
                        thead
                            tr
                                th Slot
                                th Participant
                                th Status
                                th Warnings
                        tbody#recommendationRows
                            tr(data-empty-state)
                                td.colspan-4.text-center.text-secondary.pt-3 No recommendations yet.
    if data.participantList && data.participantList.length > 0
        hr
        h4.mt-2 Participants
        .table-responsive
            table.table.table-dark.table-bordered
                thead
                    tr
                        th.text-center Name
                        th.text-center # Assigned
                        th.text-center Roles
                tbody
                    for part in data.participantList
                        tr
                            td.text-center #{part.name}
                            td.text-center #{part.count}
                            td.text-center
                                for role in part.roles
                                    if role !== 'default'
                                        p.my-1 #{role}

    // Assignment warnings modal
    #assignmentWarningModal.modal.fade(tabindex="-1" aria-labelledby="assignmentWarningTitle" aria-hidden="true")
        .modal-dialog
            .modal-content.text-bg-dark
                .modal-header
                    h5#assignmentWarningTitle.modal-title
                        i.bi.bi-exclamation-triangle.me-2
                        | Assignment warnings
                    button.btn-close(data-bs-dismiss="modal" aria-label="Close")
                .modal-body
                    p.small.text-secondary.mb-2 Potential issues were detected for this slot:
                    strong#assignmentWarningSlot.d-block.mb-2
                    ul#assignmentWarningList.list-group.list-group-flush
                .modal-footer
                    button#assignmentWarningCancel.btn.btn-outline-secondary(type="button" data-bs-dismiss="modal") Cancel
                    button#assignmentWarningConfirm.btn.btn-warning(type="button")
                        i.bi.bi-check2.me-1
                        | Continue anyway


block scripts
    script(type="module" src="/js/activity.gen.js")
    script.
        window.Surveyor.entityId = "#{data.plan.id}";
        window.Surveyor.allRoles = !{JSON.stringify(data.roles.allRoles || []).replace(/</g, '\\u003c')};