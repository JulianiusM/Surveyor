//- views/event/event-view.pug — Event view + registration page
extends ../layout

block meta
    - const ev = data.event || data; // tolerate different controller shapes
    title #{ev.title} | Event

block title
    h1.card-header.text-center
        i.bi.bi-calendar2-event.me-2
        | #{ev.title}

block content
    -
        const ownerId = ev.ownerId;
        const startDate = ev.startDate;
        const endDate = ev.endDate;
        const location = ev.location || '';
        const deadline = ev.bindingDeadline;
        const reg = data.registration;
        const full = data.isFull ?? true;
        const participants = data.participants || [];

        const isAuthed = !!(user || guest);

    // ─── Event meta ───────────────────────────────────────────
    .card.mb-3.bg-dark.text-white.border-secondary-subtle
        .card-body
            .row
                .col-md-6
                    dl.row.mb-0
                        dt.col-sm-4 Dates
                        dd.col-sm-8
                            span#startSpan.me-1(data-start=startDate) #{startDate}
                            | →
                            span#endSpan.ms-1(data-end=endDate) #{endDate}
                        if location
                            dt.col-sm-4 Location
                            dd.col-sm-8 #{location}
                        if ev.maxParticipants
                            dt.col-sm-4 Max. / registered participants
                            dd.col-sm-8 #{ev.maxParticipants} / #{participants.length}
                        if deadline
                            dt.col-sm-4 Binding deadline
                            dd.col-sm-8
                                p Event timezone (#{ev.timezone || 'UTC'}):
                                    span.ms-2#deadlineTZ(data-tz=ev.timezone) #{new Date(deadline).toLocaleString(undefined, {timeZone: ev.timezone || 'UTC'})}
                                p Your timezone:
                                    span.ms-2#deadlineText(data-date=new Date(deadline).toISOString()) #{new Date(deadline).toUTCString()}
                                    span#deadlineCountdown.text-info.ms-2
                .col-md-6
                    if ev.description
                        label.form-label Description
                        p
                            - const lines = ev.description.split('\n')
                            each line, i in lines
                                | #{line}
                                if i < lines.length - 1
                                    br

            if permData.entity.has('ACCESS_ADMIN')
                .row
                    .col-12.d-flex.justify-content-end.gap-2
                        a.btn.btn-primary(href=`/event/${ev.id}/admin`)
                            i.bi.bi-check2-circle.me-1
                            | Event administration dashboard


    // ─── Scenario 1 & 2: Registration / Update / Cancel ──────
    if isAuthed
        if !reg
            if !full
                .card.mb-3.bg-dark.text-white.border-secondary-subtle
                    .card-header.py-2
                        i.bi.bi-person-plus.me-2
                        | Register for this event
                    .card-body
                        form.row.g-3#registrationForm
                            .col-md-6
                                label.form-label(for="arrivalDate")
                                    i.bi.bi-box-arrow-in-right.me-1
                                    | Arrival date *
                                input#arrivalDate.form-control.text-bg-dark(type="date" name="arrivalDate" required min=startDate max=endDate)
                            .col-md-6
                                label.form-label(for="departureDate")
                                    i.bi.bi-box-arrow-right.me-1
                                    | Departure date *
                                input#departureDate.form-control.text-bg-dark(type="date" name="departureDate" required min=startDate max=endDate)

                            //- dietary (shown only when required)
                            if ev.require_dietary_info || ev.requireDietaryInfo
                                .col-12
                                    label.form-label
                                        i.bi.bi-egg-fried.me-1
                                        | Dietary preferences *
                                    .row.row-cols-3.row-cols-md-4.g-2
                                        each opt in ['meat','fish','vegetarian','vegan','halal','kosher','allergies']
                                            .col
                                                .form-check
                                                    input.form-check-input(type="checkbox" name="dietary" value=opt id=`diet-${opt}`)
                                                    label.form-check-label(for=`diet-${opt}`)= opt.charAt(0).toUpperCase() + opt.slice(1)
                                    .mt-2
                                        label.form-label(for="allergyNotes") Allergies (if selected)
                                        input#allergyNotes.form-control.text-bg-dark(type="text" name="allergyNotes" placeholder="e.g., peanuts, lactose")

                            if data.regToken
                                input(type="hidden" name="regToken" value=data.regToken)

                            .col-12.d-flex.justify-content-end.gap-2
                                button.btn.btn-success(type="submit")
                                    i.bi.bi-check2-circle.me-1
                                    | Save registration
            else
                .alert.alert-danger
                    i.bi.bi-ban.me-2
                    | This event is full.
        else
            - const regDiet = reg.dietaryChoices ? reg.dietaryChoices.map(d => d.choice.toLowerCase()) : [];
            - const regAllergies = reg.dietaryChoices ? reg.dietaryChoices.find(d => d.choice === "ALLERGIES")?.additionalInfo : '';
            .card.mb-3.bg-dark.text-white.border-secondary-subtle
                .card-header.py-2
                    i.bi.bi-person-check.me-2
                    | Your registration
                .card-body
                    .row.g-3
                        .col-md-6
                            label.form-label Current arrival
                            p#arrival(data-start=reg.arrivalDate) #{reg.arrivalDate}
                        .col-md-6
                            label.form-label Current departure
                            p#departure(data-end=reg.departureDate) #{reg.departureDate}
                    hr
                    form.row.g-3#registrationForm
                        .col-md-6
                            label.form-label(for="arrivalDate")
                                i.bi.bi-pencil.me-1
                                | Change arrival
                            input#arrivalDate.form-control.text-bg-dark(
                                type="date" name="arrivalDate" required
                            min=startDate max=endDate
                                value=reg.arrivalDate)
                        .col-md-6
                            label.form-label(for="departureDate")
                                i.bi.bi-pencil.me-1
                                | Change departure
                            input#departureDate.form-control.text-bg-dark(
                                type="date" name="departureDate" required
                            min=startDate max=endDate
                                value=reg.departureDate)
                        if ev.require_dietary_info || ev.requireDietaryInfo
                            .col-12
                                label.form-label
                                    i.bi.bi-egg-fried.me-1
                                    | Dietary preferences *
                                .row.row-cols-3.row-cols-md-4.g-2
                                    each opt in ['meat','fish','vegetarian','vegan','halal','kosher','allergies']
                                        - const checked = regDiet.includes(opt);
                                        .col
                                            .form-check
                                                input.form-check-input(type="checkbox" name="dietary" value=opt id=`diet-${opt}` checked=checked)
                                                label.form-check-label(for=`diet-${opt}`)= opt.charAt(0).toUpperCase() + opt.slice(1)
                                .mt-2
                                    label.form-label(for="allergyNotes") Allergies (if selected)
                                    input#allergyNotes.form-control.text-bg-dark(
                                        type="text" name="allergyNotes" placeholder="e.g., peanuts, lactose" value=regAllergies)
                        .col-12.d-flex.justify-content-end.gap-2
                            button.btn.btn-primary(type="submit")
                                i.bi.bi-save.me-1
                                | Update
                            button.btn.btn-outline-danger#cancelRegistrationBtn(type="button")
                                i.bi.bi-x-circle.me-1
                                | Cancel registration

            if data.invoicePools && data.invoicePools.length
                .accordion.accordion-dark.mb-3#participantInvoiceAccordion
                    .accordion-item.bg-dark.text-white.border-secondary-subtle
                        h2.accordion-header
                            button.accordion-button.collapsed.text-white(type="button" data-bs-toggle="collapse" data-bs-target="#participantInvoiceCollapse" aria-expanded="false" aria-controls="participantInvoiceCollapse")
                                i.bi.bi-cash-coin.me-2
                                | Invoice pools & payments
                        #participantInvoiceCollapse.accordion-collapse.collapse
                            .accordion-body
                                +invoiceSubmission(ev.id, data.participantPools, 'participant', data.participantInvoices, data.invoicePools)
                                if data.participantPools && data.participantPools.length
                                    .mt-4
                                        +participantTakeoverList(data.participantPools, data.participants)
                                +participantShareSummary(data.registration.id, data.invoicePools)
    else
        .alert.alert-info.mx-1
            i.bi.bi-info-circle.me-2
            | Log in or use your guest link to register for this event.

    // ─── Associated content within this event ────────────────
    if reg
        .row
            - let shownSegments = 0;
            if permData.entity.has("ACCESS_ITEMS")
                .accordion.accordion-dark#entityLists
                    if data.surveys && data.surveys.length > 0
                        - shownSegments++;
                        +entityList(
                            'sec-surveys',
                            'Event surveys',
                            'bi-clipboard-data',
                            data.surveys,
                            'survey',
                            `/survey/create?eventId=${ev.id}`,
                            'Create new survey',
                            'bi-plus-circle',
                            'No surveys in this event yet.',
                            'bi-clipboard-check',
                            false
                        )

                    if data.packingLists && data.packingLists.length > 0
                        - shownSegments++;
                        +entityList(
                            'sec-pack',
                            'Event packing lists',
                            'bi-box-seam',
                            data.packingLists,
                            'packing',
                            `/packing/create?eventId=${ev.id}`,
                            'Create new packing list',
                            'bi-plus-circle',
                            'No packing lists in this event yet.',
                            'bi-bag-check',
                            false
                        )

                    if data.activityPlans && data.activityPlans.length > 0
                        - shownSegments++;
                        +entityList(
                            'sec-activity',
                            'Event activity plans',
                            'bi-calendar',
                            data.activityPlans,
                            'activity',
                            `/activity/create?eventId=${ev.id}`,
                            'Create new activity plan',
                            'bi-calendar-plus',
                            'No activity plans in this event yet.',
                            'bi-calendar-check',
                            false
                        )

                    if data.driverLists && data.driverLists.length > 0
                        - shownSegments++;
                        +entityList(
                            'sec-drivers',
                            'Event drivers lists',
                            'bi-car-front',
                            data.driverLists,
                            'drivers',
                            `/drivers/create?eventId=${ev.id}`,
                            'Create new drivers list',
                            'bi-plus-circle',
                            'No drivers lists in this event yet.',
                            'bi-car-front',
                            false
                        )
            if shownSegments === 0
                .alert.alert-info
                    i.bi.bi-info-circle.me-2
                    | No actions are currently added to the event.

        if permData.entity.has("ACCESS_PARTICIPANTS")
            +eventParticipants({
                eventId: ev.id,
                apiList: `/api/event/${ev.id}/participants`,
                startDate: startDate,
                endDate: endDate,
            })

    +takeoverModal('takeoverModal')


block scripts
    script(type="module" src="/js/events.gen.js")
    script.
        window.Surveyor.eventId = "#{ev.id}";
    script#participantsData(type="application/json")!= JSON.stringify(data.participants || []).replace(/<\/script>/g, '<\\/script>')
    if reg
        script#registrationData(type="application/json")!= JSON.stringify({id: reg.id})
