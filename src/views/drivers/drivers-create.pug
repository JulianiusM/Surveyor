//- views/packing/packing-create.pug  – überarbeitetes „Create“-Formular
extends ../layout

block meta
    title Create Drivers List | Surveyor

block title
    .card-header.d-flex.justify-content-between.align-items-center
        h1.card-title.mb-0
            i.bi.bi-car-front.me-2
            | Create drivers list
        a.btn.btn-sm.btn-outline-light(href="/help/drivers_lists" title="Help with drivers lists")
            i.bi.bi-question-circle

block content
    -
        let parsed = {}, parsedData = [];
        let parsedEventData = {};
        if (data) {
            if (data.entity) {
                parsed = data.entity;
            } else {
                parsed = data;
            }
            if (data.data) {
                parsedData = data.data;
            } else {
                parsedData = data.items;
            }
            if (data.eventId) {
                parsedEventData.id = data.eventId;
            }
            if (data.events) {
                parsedEventData.events = data.events;
            }
        }

        let eventIdQuery = '';
        if (parsedEventData.id) {
            eventIdQuery = `?eventId=${parsedEventData.id}`
        }

    form#packingForm(action=`/drivers/create${eventIdQuery}` method="POST")
        // Titel
        .mb-3
            label.form-label(for="title")
                i.bi.bi-tag.me-1
                | Title *
            input#title.form-control.text-bg-dark(
                type="text"
                name="title"
                required
                value=(parsed.title || ''))

        .row.mb-3
            .col-md-12
                label.form-label(for="desc")
                    i.bi.bi-pencil-square.me-1
                    | Description
                textarea#desc.form-control.text-bg-dark(name="description")
                    | #{parsed.description || ''}

        .row.mb-3
            .col-md-12
                +entityPicker('event_id', parsedEventData.events, {label: 'Assign to event', value: parsedEventData.id})

        .row.mb-3
            .col-md-12
                +permMatrix(['participant', 'guest', 'authenticated', 'public'], perms.permMeta, perms.defaultPerms, perms.presets, 'defaultPerms')

        // Buttons
        // Items table (managed by JavaScript)
        .mb-3
            table.table.table-dark
                tbody#itemTable
        
        .d-flex.justify-content-between.align-items-center
            button.btn.btn-success(type="submit")
                i.bi.bi-check-lg.me-1
                | Create list
        input(type="hidden" name="items" id="itemsJson")

block scripts
    script(type="module", src="/js/drivers-create.gen.js")