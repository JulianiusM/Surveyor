extends layout

block title
    .card-header.d-flex.justify-content-between.align-items-center
        h1.card-title.mb-0
            i.bi.bi-question-circle.me-2
            | #{title}
        a.btn.btn-sm.btn-outline-light(href="/")
            i.bi.bi-house.me-1
            | Home

block content
    .row
        //- Sidebar navigation for documentation
        .col-md-3.mb-3
            .card.bg-dark.text-white
                .card-header
                    h5.mb-0
                        i.bi.bi-list-ul.me-2
                        | Documentation
                .list-group.list-group-flush
                    each doc in docsList
                        - const isActive = currentDoc === doc.path.toLowerCase() || (currentDoc === 'readme' && doc.path === 'readme')
                        - const docUrl = doc.path === 'readme' || doc.path === 'README' ? '/help' : `/help/${doc.path.toLowerCase()}`
                        a.list-group-item.list-group-item-action(
                            href=docUrl,
                            class=isActive ? 'active bg-primary' : 'bg-dark text-white border-secondary'
                        )= doc.title

        //- Main content area
        .col-md-9
            .card.bg-dark.text-white
                .card-body.help-content
                    //- Render the markdown content as HTML
                    != content

block link
    style.
        /* Help content styling to match dark theme */
        .help-content {
            color: #e9ecef;
        }
        .help-content h1,
        .help-content h2,
        .help-content h3,
        .help-content h4,
        .help-content h5,
        .help-content h6 {
            color: #ffffff;
            margin-top: 1.5rem;
            margin-bottom: 1rem;
            font-weight: 600;
        }
        .help-content h1 {
            font-size: 2rem;
            border-bottom: 2px solid #495057;
            padding-bottom: 0.5rem;
        }
        .help-content h2 {
            font-size: 1.75rem;
            border-bottom: 1px solid #495057;
            padding-bottom: 0.4rem;
        }
        .help-content h3 {
            font-size: 1.5rem;
        }
        .help-content h4 {
            font-size: 1.25rem;
        }
        .help-content p {
            margin-bottom: 1rem;
            line-height: 1.6;
        }
        .help-content a {
            color: #6ea8fe;
            text-decoration: none;
        }
        .help-content a:hover {
            color: #9ec5fe;
            text-decoration: underline;
        }
        .help-content ul,
        .help-content ol {
            margin-bottom: 1rem;
            padding-left: 2rem;
        }
        .help-content li {
            margin-bottom: 0.5rem;
        }
        .help-content code {
            background-color: #343a40;
            color: #f8f9fa;
            padding: 0.2rem 0.4rem;
            border-radius: 0.25rem;
            font-family: 'Courier New', monospace;
            font-size: 0.9em;
        }
        .help-content pre {
            background-color: #212529;
            color: #f8f9fa;
            padding: 1rem;
            border-radius: 0.5rem;
            overflow-x: auto;
            border: 1px solid #495057;
        }
        .help-content pre code {
            background-color: transparent;
            padding: 0;
        }
        .help-content blockquote {
            border-left: 4px solid #6c757d;
            padding-left: 1rem;
            margin-left: 0;
            color: #adb5bd;
            font-style: italic;
        }
        .help-content table {
            width: 100%;
            margin-bottom: 1rem;
            border-collapse: collapse;
        }
        .help-content th,
        .help-content td {
            padding: 0.75rem;
            border: 1px solid #495057;
        }
        .help-content th {
            background-color: #343a40;
            font-weight: 600;
        }
        .help-content td {
            background-color: #212529;
        }
        .help-content hr {
            border-color: #495057;
            margin: 2rem 0;
        }
        .help-content img {
            max-width: 100%;
            height: auto;
            border-radius: 0.5rem;
            margin: 1rem 0;
        }
        /* Sidebar styling */
        .list-group-item {
            border: 1px solid #495057;
        }
        .list-group-item:hover {
            background-color: #343a40 !important;
        }
        .list-group-item.active {
            border-color: #0d6efd;
        }
