//- views/index.pug – Facelifted Landing Page
extends layout

block meta
    title Surveyor – Create and Participate in Surveys Easily
    meta(name="description" content="Surveyor is a platform for creating and participating in custom surveys. Perfect for scheduling, decision-making, and collecting group opinions.")
    meta(name="keywords" content="survey, online polls, scheduling, decision making, voting, group surveys, Surveyor")
    meta(name="author" content="Surveyor Team")
    meta(property="og:title" content="Surveyor – Custom Survey Platform")
    meta(property="og:description" content="Join Surveyor to create and participate in tailored surveys for your scheduling and decision-making needs.")
    meta(property="og:image" content="/img/logo.png")
    meta(property="og:url" content="https://your-surveyor-site.com")
    meta(name="twitter:card" content="summary_large_image")

block title
    h1.card-header.text-center
        i.bi.bi-bar-chart-fill.me-2
        | Welcome to Surveyor

block content
    //── Call to Action ─────────────────────────────────────
    if user
        p.lead.text-center.mt-3
            | Hello, #{user.username}! What would you like to create today?
        .d-flex.justify-content-center.gap-3.my-4
            a.btn.btn-success.btn-lg(href="/survey/create")
                i.bi.bi-plus-circle.me-2
                | Create Survey
            a.btn.btn-success.btn-lg(href="/packing/create")
                i.bi.bi-bag-plus.me-2
                | Create Packing List
            a.btn.btn-outline-info.btn-lg(href="/users/dashboard")
                i.bi.bi-speedometer2.me-2
                | Your Dashboard
    else
        p.lead.text-center.mt-3
            | Welcome! Log in or register to start creating surveys or packing lists.
        .d-flex.justify-content-center.gap-3.my-4
            a.btn.btn-primary.btn-lg(href="/users/login")
                i.bi.bi-box-arrow-in-right.me-2
                | Login
            a.btn.btn-outline-primary.btn-lg(href="/users/register")
                i.bi.bi-person-plus.me-2
                | Register

    hr.my-5.border-secondary-subtle

    //── How It Works ────────────────────────────────────────
    h2.text-center.mb-4
        i.bi.bi-lightbulb-fill.me-2
        | How It Works

    .row.text-center
        .col-md-4.mb-4
            i.bi.bi-pencil-square.display-4.mb-2
            h5 Create Surveys
            p
                | Define custom surveys with options or dates to match your needs.
        .col-md-4.mb-4
            i.bi.bi-bag-fill.display-4.mb-2
            h5 Create Packing Lists
            p
                | Build lists of items to bring, assign participants or guests.
        .col-md-4.mb-4
            i.bi.bi-bar-chart-fill.display-4.mb-2
            h5 Collaborate & Decide
            p
                | Invite participants, vote or assign items, and analyze results in real time.