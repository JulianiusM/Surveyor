extends ../layout

block meta
    title #{data.plan.title} | Activity planner

block title
    h1.card-header.text-center
        i.bi.bi-calendar-check.me-2
        | #{data.plan.title}

block content
    //- helper in pug (this won’t be sent to the client)
    -
        function fmtISO(date) {
            const y = date.getUTCFullYear();
            const m = String(date.getUTCMonth() + 1).padStart(2, '0');
            const d = String(date.getUTCDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function toDate(val) {
            const [y, m, d] = val.split('-').map(Number);
            return new Date(Date.UTC(y, m - 1, d));
        }
        const dayNames = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
        const start = toDate(data.plan.start_date);
        const end = toDate(data.plan.end_date);

        const weeks = [];
        const monday = new Date(start);
        monday.setDate(monday.getDate() - ((monday.getDay() + 6) % 7));
        while (monday <= end) {
            weeks.push(new Date(monday));
            monday.setDate(monday.getDate() + 7);
        }

        const owner = user && user.id === data.plan.owner_id
        const manage = owner || (data.plan.guest_manage && (guest || user))

    // Owner settings toggles
    if owner
        .card.mb-3.bg-dark.text-white.border-secondary-subtle
            .card-header.py-2
                i.bi.bi-gear-fill.me-2
                | List settings
            .card-body.py-2
                form#flagForm(class="row g-3")
                    .col-md-6.d-flex.align-items-center
                        .form-check.form-switch
                            input#allowAddSwitch.form-check-input(
                                type="checkbox"
                                autocomplete="off"
                                checked= data.plan.allow_guest_add == 1 )
                            label.form-check-label(for="allowAddSwitch") Guests can add slots
                    .col-md-6.d-flex.align-items-center
                        .form-check.form-switch
                            input#guestManageSwitch.form-check-input(
                                type="checkbox"
                                autocomplete="off"
                                checked= data.plan.guest_manage == 1 )
                            label.form-check-label(for="guestManageSwitch") Guests may manage plan

    //Erste Zeile: Metainfos / Badge
    .d-flex.justify-content-between.align-items-center.mb-3
        //- Titel / Hauptlabel links
        span.fs-6.fw-semibold
            i.bi.bi-people-fill.me-1
            | Participants:
            span.badge.bg-light.text-dark.ms-1 #{data.counters.participants}

        //── Items + Offene / Leere
        span.fs-6.fw-semibold
            i.bi.bi-card-checklist.me-1
            | Slots:
            span.badge.bg-light.text-dark.ms-1 #{data.slots.length}
            span.badge.bg-secondary-subtle.text-secondary-emphasis.ms-1
                i.bi.bi-box-arrow-up-right.me-1
                | #{data.counters.open} open
            span.badge.bg-danger-subtle.text-danger-emphasis.ms-1
                i.bi.bi-slash-circle.me-1
                | #{data.counters.empty} unassigned


        .d-flex.flex-wrap.gap-2
            // Einstellungen
            if data.plan.allow_guest_add
                span.badge.bg-info-subtle.text-info-emphasis
                    i.bi.bi-pencil-square.me-1
                    | Guests can add slots
            if data.plan.guest_manage
                span.badge.bg-warning-subtle.text-warning-emphasis.ms-1
                    i.bi.bi-tools.me-1
                    | Guests can manage

    each week in weeks
        h4.mt-4.mb-2 Week of #{fmtISO(week)}
        .table-responsive
            table.table.table-dark.table-bordered.activity-table
                thead
                    tr
                        // @formatter:off
                        - for (let i = 0; i < 7; i++) {
                        -   const cur = new Date(week); cur.setDate(cur.getDate() + i);
                        -   if (cur < start || cur > end) continue;
                            th.text-center.small(data-date=fmtISO(cur))
                                span.day #{dayNames[i]}
                                br
                                span.date #{fmtISO(cur)}
                        - }
                        // @formatter:on
                tbody
                    //- figure out how many rows we need
                    // @formatter:off
                    // iterate 7 weekdays once
                    - for (let i = 0; i < 7; i++) {
                    - const cur = new Date(week); cur.setDate(cur.getDate() + i)
                    - if (cur < start || cur > end) continue;
                        td
                            // ▶ every slot now shares this parent
                            .slot-container(data-date=fmtISO(cur))
                                - const daySlots = (data.slots[fmtISO(cur)] || []);
                                if daySlots.length > 0
                                    each slot, idx in daySlots
                                        - const my = data.assignments.includes(slot.id)
                                        .slot.border.rounded.p-2.mb-2.d-grid.gap-1(data-slotid=slot.id draggable=manage ? 'true' : null)

                                            // editable title
                                            span.fw-semibold(data-edit="title" data-slotid=slot.id)= slot.title

                                            // editable description
                                            small(data-edit="description" data-slotid=slot.id)= slot.description || ''

                                            // badge + editable max
                                            span.badge.bg-secondary.w-100.text-center
                                                span(data-count)= slot.assigned_count
                                                |  /&nbsp;
                                                span(data-edit="maxAssignees" data-slotid=slot.id data-max)= slot.max_assignees

                                            // assignees
                                            ul.list-unstyled.mb-0
                                                each asg in data.assigneeLists[slot.id] || []
                                                    li.d-flex.align-items-center.gap-1
                                                        i.bi.bi-person-fill
                                                        span.flex-grow-1= asg.name
                                                        if manage
                                                            button.btn.btn-sm.btn-outline-danger.ms-1(
                                                                data-owner-remove
                                                                data-assignid=asg.id) ×

                                            // actions
                                            .d-flex.gap-2.mt-1
                                                if my
                                                    button.btn.btn-sm.btn-outline-danger.flex-grow-1(
                                                        data-action="unassign") Leave
                                                else if slot.assigned_count < slot.max_assignees
                                                    button.btn.btn-sm.btn-outline-success.flex-grow-1(
                                                        data-action="assign") Join
                                                else
                                                    span.badge.bg-secondary.flex-grow-1.text-center Full
                                                if manage
                                                    button.btn.btn-sm.btn-outline-danger(
                                                        data-delete-slot data-slotid=slot.id
                                                        draggable="false")
                                                        i.bi.bi-trash
                                else
                                    span.badge.w-100.text-center
                                        i.bi.bi-info-circle.me-2
                                        | No slots for this day!
                    - }
                    // @formatter:on
                // ★ add-slot buttons row
                tfoot
                    tr
                        // @formatter:off
                        - for(let i=0;i<7;i++){
                        - const cur=new Date(week);cur.setDate(cur.getDate() + i)
                        - if(cur<start||cur>end) continue;
                            td.text-center
                                button.btn.btn-sm.btn-outline-info.w-100(data-add-slot data-date=fmtISO(cur)) + Slot
                        - }
                        // @formatter:on

block scripts
    script(src="/js/activity.js")
    script.
        window.ACT_PLAN_ID = "#{data.plan.id}";