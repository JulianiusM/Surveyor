doctype html
html
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1, shrink-to-fit=no")
        block meta

        link(rel="icon", type="image/png", sizes="32x32", href="/img/favicon-32x32.png")
        link(rel="icon", type="image/png", sizes="16x16", href="/img/favicon-16x16.png")
        link(rel="icon", type="image/png", sizes="200x200", href="/img/logo.png")
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
        link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH", crossorigin="anonymous")
        link(rel="stylesheet", href="/style/style.css")
        block link

        script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js")
        script(type="text/javascript", src="/js/module_functions.js")
        block scripts
            //Stub script to avoid js errors on console
            script(type="text/javascript", src="/js/stub.js")

    body(onload="init()" class="bg-secondary")
        header
        nav(class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow")
            .container-fluid
                a(class="navbar-brand" href="/") Surveyor
                button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#navbarNav", aria-controls="navbarNav", aria-expanded="false", aria-label="Toggle navigation")
                    span.navbar-toggler-icon
                .collapse.navbar-collapse#navbarNav
                    ul(class="navbar-nav me-auto")
                        li(class="nav-item")
                            a(class="nav-link", href="/survey/create") Create Survey

                    ul(class="navbar-nav ms-auto")
                        hr(class="d-block d-lg-none my-3 border-info")
                        if(user)
                            li(class="nav-item dropdown")
                                a(class="nav-link dropdown-toggle text-light" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false")
                                    i(class="bi bi-person-circle me-1") &nbsp; #{user.username}
                                ul(class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu")
                                    li
                                        a(class="dropdown-item", href="/users/dashboard") Dashboard
                                    //li
                                        a(class="dropdown-item", href="/users/settings") Settings
                                    li
                                        hr(class="dropdown-divider")
                                    li
                                        a(class="dropdown-item text-danger", href="/users/logout") Logout
                        else
                            li(class="nav-item")
                                a(class="nav-link", href="/users/login") Login
                            li(class="nav-item")
                                a(class="nav-link", href="/users/register") Register

        main(class="container-fluid")
            block alert
                include modules/module_alert.pug

            block body
                //Default page body will be displayed as a card
                div(class="card mt-3 bg-dark text-white")
                    block title
                    div(class="card-body")
                        block content

            //Placeholder at the end of the page for the footer to float above
            div(class="d-block mt-3 mb-0 pt-3 pb-3")
                p
            footer(class="bg-dark text-white text-center mt-3 mb-0 pt-2 pb-1 fixed-bottom")
                p © #{new Date().getFullYear()} Surveyor by JundM100 Development. All Rights Reserved.

        script(type="text/javascript", src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js", integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz", crossorigin="anonymous")
