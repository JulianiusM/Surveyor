extends ../layout

block meta
    title #{data.list.title} | Surveyor

block title
    h1.card-header.text-center #{data.list.title}

block scripts
    script(src="/js/packing.js")
    script.
        window.PACK_LIST_ID = "#{data.list.id}";

block content
    - const owner = user && user.id === data.list.owner_id
    - const manage = owner || (data.list.guest_manage && (guest || user))

    //Erste Zeile: Metainfos / Badge
    .d-flex.justify-content-between.align-items-center.mb-3
        span
            i.bi.bi-people-fill.me-1
            | Participants: #{data.items.length}
        if data.list.allow_guest_add
            span.badge.bg-info-subtle.text-info-emphasis
                i.bi.bi-pencil-square.me-1
                | Guests can add items
        if data.list.guest_manage
            span.badge.bg-warning-subtle.text-warning-emphasis.ms-1
                i.bi.bi-tools.me-1
                | Guests can manage

    //Tabelle
    .table-responsive
        table.table.table-dark.table-hover.table-bordered.align-middle(data-assignable)
            thead
                tr
                    th.text-center.w-25 Assignees
                    th.text-center.w-25 Item
                    th.text-center.w-25 Description
                    th.text-center.w-15 Assigned&nbsp;/&nbsp;Max
                    th.text-center.w-10 Action
            tbody(data-reorderable=manage ? true : null)
                each item in data.items
                    - const my     = data.assignments.includes(item.id)
                    - const isFull = item.assigned_count >= item.max_assignees
                    tr(data-itemid=item.id)
                        // Assignees
                        td.text-center
                            ul.list-unstyled.mb-0
                                each asg in data.assigneeLists[item.id] || []
                                    li.d-flex.align-items-center.gap-1
                                        i.bi.bi-person-fill
                                        span.flex-grow-1= asg.name
                                        if manage
                                            button.btn.btn-sm.btn-outline-danger(
                                                data-assignid=asg.id
                                                data-owner-remove
                                                aria-label="Remove"
                                            ) &times;

                        // Title
                        if manage
                            td(data-edit="title" data-itemid=item.id)= item.title
                        else
                            td= item.title

                        // Description
                        if manage || data.list.allow_guest_add
                            td(data-edit="description" data-itemid=item.id)= item.description
                        else
                            td= item.description

                        // Assigned / Max
                        if manage
                            td.text-center(
                                data-edit="maxAssignees"
                                data-itemid=item.id
                            )
                                span(data-count)= item.assigned_count
                                |  /&nbsp;
                                span(data-max)= item.max_assignees
                        else
                            td.text-center
                                span(data-count)= item.assigned_count
                                |  /&nbsp;
                                span(data-max)= item.max_assignees

                        // Action
                        td.text-center
                            if my
                                button.btn.btn-sm.btn-outline-danger(
                                    data-action="unassign") Remove
                                if isFull
                                    span.badge.bg-secondary.ms-1 Full
                            else if !isFull && data.assignments !== undefined
                                button.btn.btn-sm.btn-outline-success(
                                    data-action="assign") Take
                            else
                                span.badge.bg-secondary Full

    // Sichtbar für Owner oder bei erlaubtem Gast-Add
    if data.list.allow_guest_add || manage
        hr
        .card.bg-dark.text-light.border-secondary.mb-3
            .card-header.p-2.d-flex.align-items-center
                i.bi.bi-plus-circle.me-2
                span.flex-grow-1 Add new item
                small.text-muted.fst-italic.ms-2 (fill all fields)

            form#quickAddForm.card-body(class="row gy-2 gx-2 align-items-end"
                action=`/packing/${data.list.id}/items`
                method="post")
                //Titel
                .col-md-4
                    label.form-label.mb-1(for="title") Title *
                    input#title.form-control.text-bg-dark(
                        name="title" placeholder="e.g. Camping stove" required)

                //Beschreibung
                .col-md-4
                    label.form-label.mb-1(for="desc") Description
                    input#desc.form-control.text-bg-dark(
                        name="description" placeholder="optional")

                //Max Assignees
                .col-md-2
                    label.form-label.mb-1(for="max") Max #
                    input#max.form-control.text-bg-dark(
                        type="number" min="1" value="1" name="max")

                //Add-Button
                .col-md-2.d-grid
                    button.btn.btn-success(type="submit")
                        i.bi.bi-check-lg.me-1
                        | Add


