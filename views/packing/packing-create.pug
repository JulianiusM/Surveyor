//- views/packing/packing-create.pug  – überarbeitetes „Create“-Formular
extends ../layout

block meta
    title Create Packing List | PackMaster

block title
    h1.card-header.text-center
        i.bi.bi-bag-plus.me-2
        | Create packing list

block content
    -
        let parsed, parsedData;
        if (data) {
            if (data.entity) {
                parsed = data.entity;
            } else {
                parsed = {
                    description: data.description,
                    allow_guest_add: data.allowGuestAdd,
                    guest_manage: data.guestManage,
                }
            }
            if (data.data) {
                parsedData = data.data;
            } else {
                parsedData = data.items;
            }
        } else {
            parsed = {};
            parsedData = [];
        }

    form#packingForm(action="/packing/create" method="POST")
        // Titel
        .mb-3
            label.form-label(for="title")
                i.bi.bi-tag.me-1
                | Title *
            input#title.form-control.text-bg-dark(
                type="text"
                name="title"
                required
                value=data && data.title ? data.title : '')

        // Optionen
        .row.mb-3
            .col-md-6
                .form-check
                    input#allowAdd.form-check-input(type="checkbox" name="allowGuestAdd" checked=parsed.allow_guest_add == 1)
                    label.form-check-label(for="allowAdd")
                        i.bi.bi-plus-circle.me-1
                        | Guests can add items
            .col-md-6
                .form-check
                    input#guestManage.form-check-input(type="checkbox" name="guestManage" checked=parsed.guest_manage == 1)
                    label.form-check-label(for="guestManage")
                        i.bi.bi-exclamation-triangle.me-1
                        | Guests may manage list
                        span.badge.bg-danger.ms-1 DANGER

        .row.mb-3
            .col-md-12
                label.form-label(for="desc")
                    i.bi.bi-pencil-square.me-1
                    | Description
                textarea#desc.form-control.text-bg-dark(name="description"
                    value=(parsed.description ? parsed.description : ''))

        // Item-Tabelle
        .mb-3
            label.form-label
                i.bi.bi-list-ul.me-1
                | Items to pack
            .table-responsive
                table.table.table-dark.table-striped.table-bordered.align-middle
                    thead
                        tr
                            th.text-center.w-25 Item
                            th.text-center.w-50 Description
                            th.text-center.w-15 Max #
                            th.text-center.w-10 Action
                    tbody#itemTable

        // Buttons
        .d-flex.justify-content-between.align-items-center
            button#addItemBtn.btn.btn-outline-info(type="button")
                i.bi.bi-plus-circle.me-1
                | Add row
            button.btn.btn-success(type="submit")
                i.bi.bi-check-lg.me-1
                | Create list
        input(type="hidden" name="items" id="itemsJson")

block scripts
    script(type="text/javascript", src="/js/packing-create.js")
    if data && data.isDuplicate
        script.
            window.PREFILLED_ITEMS = !{JSON.stringify(parsedData)};
            window.IS_MANAGE = true;