# Server
NODE_ENV=e2e
PORT=3001
BASE_URL=http://localhost:3001

# MariaDB (E2E database only!)
E2E_DB_HOST=127.0.0.1
E2E_DB_PORT=3306
E2E_DB_USER=e2e_user
E2E_DB_PASS=e2e_password
E2E_DB_NAME=surveyor_e2e  # must contain 'e2e' (guarded in the init script)

# Seed user for tests (example)
E2E_ADMIN_EMAIL=e2e@example.com
E2E_ADMIN_PASSWORD=passw0rd!